# Vantalens .gitignore

# Hugo generated
public/
resources/
.hugo_build.lock

# Binaries (do not upload)
*.exe
*.dll
bin/
.tools/

# Logs
*.log

# Sensitive config (do not upload)
.env
.env.*
config/comment_settings.json
**/comments.json
config/_default/comment_settings.json

# System
.DS_Store
Thumbs.db
*.swp
*~

# IDE
.idea/
.vscode/

# Temp
*.tmp
*.bak

# Go cache
.go-cache/
vendor/

# Theme (downloaded, not uploaded)
themes/stack/

# Build output
build/
dist/
out/
tools/hugo/
