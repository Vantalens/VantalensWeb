# Vantalens .gitignore

# Hugo generated
public/
resources/
.hugo_build.lock
hugo_stats.json

# Binaries (do not upload)
*.exe
*.dll
*.so
*.dylib
bin/
.tools/
hugo.exe

# Logs
*.log
*.err
*.pid
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Sensitive config (do not upload)
.env
.env.*
config/comment_settings.json
**/comments.json
config/_default/comment_settings.json
**/comment_settings.json
**/*secret*
**/*private*
**/*deploy_key*
**/*ssh_key*
**/*.pem
**/*.key
**/*.p12
**/*.pfx
id_rsa*
id_ed25519*
known_hosts

# Local deployment state
.deploy/
.deploy-*/
deploy/*.local
deploy/*.log
deploy/*.pid
deploy/*.pem
deploy/*.key
deploy/*secret*
deploy/*private*
rsync-*.txt
scp-*.txt

# System
.DS_Store
Thumbs.db
*.swp
*~

# IDE
.idea/
.vscode/

# Temp
*.tmp
*.bak
*.backup
*.old
*.orig
*.zip
*.tar
*.tgz
*.tar.gz
*.7z
*.rar

# Go cache
.go-cache/
.go-mod-cache/
go-cache/
go-mod-cache/
**/.go-cache/
**/.go-mod-cache/
**/go-cache/
**/go-mod-cache/
vendor/

# Theme (downloaded, not uploaded)
themes/stack/

# TalentWriter runtime data
.talentwriter/
TalentWriter/build/
TalentWriter/data/
TalentWriter/public/
TalentWriter/.hugo_build.lock
TalentWriter/*.exe

# Build output
build/
dist/
out/
tools/hugo/
release/
releases/
tmp/
temp/
coverage/
coverage.out

# Runtime databases and generated data
*.db
*.db-*
*.sqlite
*.sqlite3
data/comments/
data/analytics/
data/articles/
config/audit.log
